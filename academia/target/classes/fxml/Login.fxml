<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.Hyperlink?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.academia.LoginController">
   <children>
      <Label text="Acesso ao Sistema">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </Label>
      
      <VBox maxWidth="250.0" spacing="5.0">
         <children>
            <Label text="CPF / Email:" />
            <TextField fx:id="campoLogin" promptText="Digite seu CPF ou Email" />
         </children>
      </VBox>
      
      <VBox maxWidth="250.0" spacing="5.0">
         <children>
            <Label text="Senha:" />
            <PasswordField fx:id="campoSenha" promptText="Digite sua senha" />
         </children>
      </VBox>
      
      <Button mnemonicParsing="false" onAction="#clicouEntrar" prefHeight="35.0" prefWidth="250.0" text="Entrar">
         <VBox.margin>
            <Insets top="15.0" />
         </VBox.margin>
      </Button>
      
      <Hyperlink text="Esqueci a senha" onAction="#clicouEsqueciSenha">
         <VBox.margin>
            <Insets top="5.0" />
         </VBox.margin>
      </Hyperlink>
   </children>
</VBox>